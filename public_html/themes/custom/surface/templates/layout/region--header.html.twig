{#
/**
 * @file
 * Surface's theme override to display the header region.
 *
 * Available variables:
 * - content: The content for this region, typically blocks.
 * - attributes: HTML attributes for the region <div>.
 * - region: The name of the region variable as defined in the theme's
 *   .info.yml file.
 *
 * @see template_preprocess_region()
 */
#}

{% if content %}
  {% embed '@layouts/site-header/site-header.twig' %}

    {% block primary %}
      {% embed '@layouts/site-navigation/site-navigation.twig' %}
        {% block menu %}
          {{ drupal_menu('main', expand=true) }}
        {% endblock %}
      {% endembed %}
      {% include '@components/mobile-button/mobile-button.twig' %}
    {% endblock %}

    {% block buttons %}
      {% include '@components/translate/translate.twig' only %}
      {% include '@components/button-search/button-search.twig' with {
        'label': 'Search',
        'is_demo': false
      } %}
      {% include '@components/contact/contact.twig' with {
        'url': '/contact',
        'text': 'Contact Sean'
      } only %}
    {% endblock %}

    {% block search %}
      {% embed '@components/site-search/site-search.twig' with {
        'data_search': 'modal',
        'has_quicklinks': drupal_menu('quick-links')|render is not empty
      } %}
        {% block quicklinks %}
          {{ drupal_menu('quick-links') }}
        {% endblock %}
      {% endembed %}
    {% endblock %}
  {% endembed %}
{% endif %}
