{% embed '@layouts/site-header/site-header.twig' with {
  'modifier':     '',
  'nav_modifier': '',
} %}
  {# Block name must match site-header.twig's {% block navigation %} for this
     override to apply. No logo_text/logo_url here — the brand link is rendered
     once by site-header's own .site-header__logo; nav is links only. #}
  {% block navigation %}
    {% include '@components/nav/nav.twig' with {
      'links': [
        { 'text': 'Maps',    'url': '#maps' },
        { 'text': 'Writing', 'url': '#writing' },
        { 'text': 'Places',  'url': '#places' },
        { 'text': 'About',   'url': '#about' },
        { 'text': 'Contact', 'url': '#contact' },
      ],
    } only %}
  {% endblock %}
{% endembed %}
