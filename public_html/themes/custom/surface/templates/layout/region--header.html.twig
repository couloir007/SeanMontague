{#
/**
 * @file
 * Surface's theme override to display the header region.
 *
 * Available variables:
 * - content: The content for this region, typically blocks.
 * - attributes: HTML attributes for the region <div>.
 * - region: The name of the region variable as defined in the theme's
 *   .info.yml file.
 *
 * @see template_preprocess_region()
 */
#}

{% if content %}
  {% embed '@layouts/site-header/site-header.twig' %}
    {% block branding_si %}
      {% include '@elements/site-branding-si/site-branding-si.twig' with {
        'logo': '/' ~ directory ~ '/images/bg/si_NMNH_rgb_horizontal.svg',
        'site_url': 'https://naturalhistory.edu',
      } only %}
    {% endblock %}
    {% block buttons %}
      {{ drupal_entity('block','languageswitcher') }}
      {% include '@elements/button-social/button-social.twig' with {
        'url': facebook_url ? facebook_url,
        'text_social': 'Facebook',
        'modifier': 'button--social button--facebook',
      } only %}
      {% include '@elements/button-social/button-social.twig' with {
        'url': flickr_url ? flickr_url,
        'text_social': 'flickr',
        'modifier': 'button--social button--flickr',
      } only %}
      {% include '@elements/button-give/button-give.twig' with {
        'url': 'https://naturalhistory.si.edu/join-us/memberships-giving/ways-give?form=FUNPCXDYESQ',
        'text': 'Donate'
      } only %}
      {% include '@elements/button-search/button-search.twig' only %}
    {% endblock %}

    {% block branding %}
      {% include '@elements/site-branding/site-branding.twig' with {
        'logo': '/' ~ directory ~ '/images/bg/Smithsonian_Ocean.svg',
        'modifier': 'site-branding site-branding--menu site-branding--horizontal-op site-branding--op',
        'site_url': path('<front>'),
      } only %}
    {% endblock %}

    {% block primary %}
      {% embed '@layouts/site-navigation/site-navigation.twig' %}
        {% block menu %}
          {{ drupal_menu('main', expand=false) }}
        {% endblock %}
      {% endembed %}
      {% include '@elements/mobile-button/mobile-button.twig' %}
    {% endblock %}

    {% block search %}
      {% embed '@layouts/site-search/site-search.twig' with {
        'data_search': data_search,
        'has_quicklinks': drupal_menu('quick-links')|render is not empty
      } %}
        {% block quicklinks %}
          {{ drupal_menu('quick-links') }}
        {% endblock %}
      {% endembed %}
    {% endblock %}
  {% endembed %}
{% endif %}
