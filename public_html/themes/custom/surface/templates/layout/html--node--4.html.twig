<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Sean Montague — Résumé</title>
  <meta name="description" content="Sean Montague — Web & Full-Stack Drupal Engineer. 19+ years building high-traffic, accessible, public-facing sites. Drupal 7–10, Laravel, PHP, MySQL, Schema.org, accessibility, SEO."/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <!-- Use system fonts for performance; swap to your site’s font stack if desired -->
  <style>
    :root {
      --sage: #BFD7C1; /* Soft Sage background accent */
      --text: #333333; /* Charcoal (AAA on sage) */
      --heading: #1A1A1A; /* Near black (AAA) */
      --muted: #666666; /* Secondary text (AA large on sage) */
      --line: #D8E6DB; /* Subtle divider (derived from sage) */
      --bg: #FFFFFF;
      --link: #244E3D; /* Deep green link; high contrast on white */
      --link-visited: #1F4033;
      --focus: #0B6E99; /* Distinct focus ring */
      --radius: 12px;
    }

    /* Base */
    html {scroll-behavior: smooth;}
    body {
      margin: 0;
      background: var(--bg);
      color: var(--text);
      font: 16px/1.6 system-ui, -apple-system, Segoe UI, Roboto, Ubuntu, Cantarell, "Helvetica Neue", Arial, "Apple Color Emoji", "Segoe UI Emoji";
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    /* Skip link */
    .skip-link {
      position: absolute; left: -9999px; top: auto; width: 1px; height: 1px; overflow: hidden;
    }
    .skip-link:focus {
      position: fixed; left: 1rem; top: 1rem; width: auto; height: auto; padding: .5rem .75rem;
      background: #fff; border: 2px solid var(--focus); border-radius: 8px; z-index: 1000;
    }

    /* Layout */
    .wrap {
      max-width: 65ch;
      margin-inline: auto;
      padding: 2rem 1rem 4rem;
    }
    header.site {
      background: var(--sage);
      padding: 2.25rem 1rem;
      border-block-end: 1px solid var(--line);
    }
    header.site .inner {
      max-width: 65ch;
      margin-inline: auto;
    }

    h1, h2, h3 {
      color: var(--heading);
      line-height: 1.25;
      margin: 0 0 .5rem;
    }
    h1 { font-size: clamp(1.8rem, 2.2vw + 1rem, 2.4rem); }
    h2 { font-size: clamp(1.25rem, 1.2vw + 1rem, 1.5rem); margin-top: 2rem; padding-top: .25rem; }
    h3 { font-size: 1.05rem; margin-top: 1.25rem; }

    p { margin: .5rem 0 1rem; }
    ul { padding-left: 1.2rem; }
    li { margin: .25rem 0; }

    /* Meta rows (role/date/location) */
    .meta {
      display: flex; flex-wrap: wrap; gap: .5rem 1rem;
      color: var(--muted);
      font-size: .95rem;
    }

    /* Section accent bars */
    .section {
      border-top: 4px solid var(--sage);
      padding-top: 1rem;
      margin-top: 1.5rem;
    }

    /* Card-ish grouping for experience items */
    .role {
      padding: .75rem 1rem;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: #fff;
    }
    .role + .role { margin-top: .75rem; }

    /* Core competencies grid */
    .grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: .25rem .75rem;
    }
    @media (min-width: 700px) {
      .grid { grid-template-columns: 1fr 1fr; }
    }

    /* Links */
    a { color: var(--link); text-decoration: underline; text-underline-offset: .15em; }
    a:visited { color: var(--link-visited); }
    a:focus { outline: 3px solid var(--focus); outline-offset: 2px; border-radius: 4px; }

    /* Utilities */
    .kicker { letter-spacing: .06em; text-transform: uppercase; font-weight: 600; font-size: .8rem; color: var(--muted); }
    .muted { color: var(--muted); }
    .badge {
      display: inline-block; background: var(--sage); color: var(--heading);
      padding: .1rem .5rem; border-radius: 999px; font-size: .8rem; border: 1px solid var(--line);
    }
    .divider { height: 1px; background: var(--line); margin: 1.25rem 0; }

    /* Footer */
    footer.site {
      margin-top: 2rem;
      border-top: 1px solid var(--line);
      padding-top: 1rem;
      color: var(--muted);
      font-size: .9rem;
    }

    /* Print tweaks */
    @media print {
      :root { --text: #000; --heading: #000; --muted: #222; }
      header.site { background: #fff; border: 0; padding: 0; }
      a { color: #000; text-decoration: none; }
      .badge { border-color: #ccc; background: #f6f6f6; }
      .wrap { padding: 0; }
      .role { border-color: #ddd; }
      .divider { background: #ddd; }
    }

    /* Reduced motion */
    @media (prefers-reduced-motion: reduce) {
      html { scroll-behavior: auto; }
    }
  </style>

  <!-- Schema.org Person JSON-LD -->
  
</head>

