{#
/**
 * @file
 * Front page template for the web_page bundle.
 *
 * Activated via surface_theme_suggestions_node_alter() when
 * node.bundle() === 'web_page' and path.matcher::isFrontPage() is TRUE.
 *
 * All hero content is pulled from web_page node fields:
 *   field_eyebrow       → hero eyebrow
 *   title               → hero name
 *   body (summary)      → hero tagline
 *   field_cta_primary   → primary CTA link
 *   field_cta_ghost     → ghost CTA link
 *   schema_geo          → map center (lat/lon)
 *   field_map_zoom      → map zoom level
 *   field_map_markers   → geo_entity references → map markers
 *   schema_topic        → topic terms with field_icon → categories strip
 *
 * Dynamic sections use drupal_view():
 *   homepage_writing    → featured articles grid
 *   homepage_places     → featured destinations grid
 *
 * @see surface_theme_suggestions_node_alter()
 * @see source/patterns/components/hero/hero.twig
 */
#}

{% extends '@layouts/site-container/site-container.twig' %}

{% block header %}
  {% include '@components/nav/nav.twig' with {
    'logo_text': 'Sean Montague <span>· Burke, VT</span>',
    'logo_url':  '/',
    'links': [
      { 'text': 'Maps',    'url': '#maps' },
      { 'text': 'Writing', 'url': '#writing' },
      { 'text': 'Places',  'url': '#places' },
      { 'text': 'About',   'url': '#about' },
      { 'text': 'Contact', 'url': '#contact' },
    ],
  } only %}
{% endblock %}

{% block main %}
  {{ attach_library('surface/site-homepage') }}

  {# ── Build map center from schema_geo geofield ────────────────────────── #}
  {% set has_geo = not node.schema_geo.isEmpty() %}
  {% set map_center = has_geo
    ? node.schema_geo.lat.value ~ ',' ~ node.schema_geo.lon.value
    : '44.593,-71.918' %}
  {% set map_zoom = node.field_map_zoom.value|default(11) %}

  {# ── Build markers from field_map_markers → geo_entity references ─────── #}
  {% set map_markers = [] %}
  {% for item in node.field_map_markers %}
    {% set geo_entity = item.entity %}
    {% if geo_entity and not geo_entity.schema_geo.isEmpty() %}
      {% set map_markers = map_markers|merge([{
        'lat':   geo_entity.schema_geo.lat,
        'lon':   geo_entity.schema_geo.lon,
        'color': geo_entity.bundle() == 'lodging' ? '#a05a00' : '#3a5a40',
        'label': '<strong>' ~ geo_entity.label.value ~ '</strong>',
      }]) %}
    {% endif %}
  {% endfor %}

  {# ── Build categories from schema_topic terms ─────────────────────────── #}
  {% set categories = [] %}
  {% for item in node.schema_topic %}
    {% set term = item.entity %}
    {% if term %}
      {% set categories = categories|merge([{
        'text': term.label,
        'icon': term.field_icon.value|default(''),
        'url':  '#places',
      }]) %}
    {% endif %}
  {% endfor %}

  {# ── CTA links ────────────────────────────────────────────────────────── #}
  {% set cta_primary = not node.field_cta_primary.isEmpty() ? {
    'text': node.field_cta_primary.title,
    'url':  node.field_cta_primary.uri,
  } : { 'text': 'Explore the Maps', 'url': '#maps' } %}

  {% set cta_ghost = not node.field_cta_ghost.isEmpty() ? {
    'text': node.field_cta_ghost.title,
    'url':  node.field_cta_ghost.uri,
  } : { 'text': 'Read the Writing', 'url': '#writing' } %}

  {# ── Hero ─────────────────────────────────────────────────────────────── #}
  {% include '@components/hero/hero.twig' with {
    'map_id':      'hero-map',
    'map_center':  map_center,
    'map_zoom':    map_zoom,
    'map_markers': map_markers,
    'eyebrow':     node.field_eyebrow.value|default('Burke, Vermont · Northeast Kingdom'),
    'name':        node.title.value,
    'tagline':     node.body.summary|default('Maps, trails, and growing things. Web developer at the Smithsonian, living and exploring in the Northeast Kingdom.'),
    'cta_primary': cta_primary,
    'cta_ghost':   cta_ghost,
    'categories':  categories,
  } only %}

  {# ── Marquee ──────────────────────────────────────────────────────────── #}
  {% include '@components/marquee/marquee.twig' with {
    'items': [
      'Kingdom Trails',
      'Burke Mountain',
      'Leaflet Mapping',
      'Permaculture',
      'Drupal',
      'Northeast Kingdom',
      'Open Source',
      'Smithsonian NMNH',
    ],
  } only %}

  {# ── Map section ──────────────────────────────────────────────────────── #}
  {% include '@collections/map-section/map-section.twig' with {
    'label':      'Interactive Maps',
    'title':      'The Kingdom, <em>mapped.</em>',
    'text':       '<p>Custom Leaflet maps of the places I know best — Kingdom Trails singletrack, Burke Mountain terrain, back-road touring routes, and the land around Burke.</p><p>Built with Leaflet.js, USGS National Map tiles, and GeoJSON from years of riding, skiing, and wandering.</p>',
    'map_id':     'featured-map',
    'map_center': map_center,
    'map_zoom':   12,
    'links': [
      { 'text': 'Kingdom Trails Network',  'url': '/places/kingdom-trails' },
      { 'text': 'Burke Mountain Ski Lines', 'url': '/places/burke-mountain' },
    ],
  } only %}

  {# ── Writing — latest featured articles ───────────────────────────────── #}
  <section class="homepage__writing" id="writing">
    <span class="homepage__eyebrow">Writing</span>
    <div class="homepage__cards-grid">
      {{ drupal_view('homepage_writing', 'block_1') }}
    </div>
  </section>

  {# ── Places & Projects ────────────────────────────────────────────────── #}
  <section class="homepage__places" id="places">
    <span class="homepage__eyebrow">Places &amp; Projects</span>
    <div class="homepage__places-grid">
      {{ drupal_view('homepage_places', 'block_1') }}
    </div>
  </section>

  {# ── About ────────────────────────────────────────────────────────────── #}
  {% include '@components/about/about.twig' with {
    'label': 'About',
    'title': 'Builder, rider, <em>grower.</em>',
    'skills': [
      'Smithsonian NMNH',
      'Drupal & Twig',
      'Leaflet & GIS / Mapping',
      'SVG & Data Visualization',
      'JavaScript / Open Source',
      'Permaculture Design',
      'Kingdom Trails regular',
    ],
    'paragraphs': [
      "I'm Sean Montague — a web developer based in Burke, Vermont, in the Northeast Kingdom. I work at the Smithsonian National Museum of Natural History, building Drupal systems, interactive maps, and data visualization tools for one of the world's great natural history institutions.",
      "This site is a personal outlet for the things I care about outside of work: riding Kingdom Trails, skiing Burke Mountain, building a food forest, and making maps of the places I know well.",
      "The technical stuff — Leaflet, GeoJSON, Twig, SVG — bleeds into the personal projects too. That's fine by me.",
    ],
  } only %}

  {# ── Contact ──────────────────────────────────────────────────────────── #}
  {% include '@components/contact/contact.twig' with {
    'label':    'Contact',
    'headline': 'Say hello.',
    'sub':      'Always happy to talk trails, maps, or growing things.',
    'email':    'sean@seanmontague.com',
  } only %}

{% endblock %}

{% block footer %}
  {% include '@components/footer/footer.twig' with {
    'brand_text':     'Sean Montague · Burke, VT',
    'copyright_text': '© 2025 Sean Montague',
    'links': [
      { 'text': 'GitHub',     'url': 'https://github.com/seanmontague' },
      { 'text': 'Drupal.org', 'url': 'https://drupal.org/u/seanmontague' },
      { 'text': 'LinkedIn',   'url': 'https://linkedin.com/in/seanmontague' },
    ],
  } only %}
{% endblock %}
