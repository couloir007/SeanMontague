{#
/**
 * @file
 * Article node template — handles all post types via schema_category.
 *
 * Map sources (any combination):
 * - schema_geoshape (file)    → GeoJSON track + elevation profile
 *                               Stats (distance, gain, loss, min, max)
 *                               computed from GeoJSON Z values by map.js
 * - schema_geo (geofield)     → map center fallback only, no marker
 * - schema_place (entity ref) → map center fallback only, no marker
 *
 * Manual stat fields (schema_distance etc.) used as display fallback
 * when schema_geoshape is not set.
 */
#}

{# ── Geo sources ── #}
{% set geoshape_media = node.schema_geoshape.entity %}
{% set geo_file       = geoshape_media ? geoshape_media.field_media_file.entity : null %}
{% set geojson_url    = geo_file ? geo_file.uri.value|file_url : null %}
{% set is_gpx = node.schema_geoshape.entity and node.schema_geoshape.entity.filename matches '/\\.gpx$/i' %}
{% set has_geoshape   = geo_file is not empty %}
{% set has_geo      = not node.schema_geo.isEmpty() %}
{% set place        = node.schema_place.entity %}
{% set has_place    = place and place.schema_latitude.value is not empty %}
{% set has_map      = has_geoshape or has_geo or has_place %}

{# ── Manual stats — fallback when no geoshape file ── #}
{% set has_stats = not node.schema_distance.isEmpty() %}

{# ── Map center fallback — overridden by fitBounds when geojson present ── #}
{% if has_geo %}
  {% set map_center = node.schema_geo.lat ~ ',' ~ node.schema_geo.lon %}
{% elseif has_place %}
  {% set map_center = place.schema_latitude.value ~ ',' ~ place.schema_longitude.value %}
{% else %}
  {% set map_center = '44.593,-71.918' %}
{% endif %}

{# ── Markers — place is center only, never a marker ── #}
{% set map_markers = [] %}

{# ── Map ID ── #}
{% set map_id = has_map ? 'article-map-' ~ node.id : '' %}

{# ── Stats — manual fields only when no geoshape ── #}
{% set stats = has_stats ? [
  { 'label': 'Distance',  'value': node.schema_distance.value,                          'unit': 'miles' },
  { 'label': 'Elevation', 'value': node.schema_elev_gain.value|number_format(0, '.', ','), 'unit': 'ft gain' },
  { 'label': 'Loss',      'value': node.schema_elev_loss.value|number_format(0, '.', ','), 'unit': 'ft loss' },
  { 'label': 'Min Elev',  'value': node.schema_elev_min.value|number_format(0, '.', ','),  'unit': 'ft' },
  { 'label': 'Max Elev',  'value': node.schema_elev_max.value|number_format(0, '.', ','),  'unit': 'ft' },
] : [] %}

{% set tiles = node.field_map_tiles.value %}

{# ── Sidebar cards ── #}
{% set sidebar_cards = [] %}
{% if is_gpx %}
  {% set sidebar_cards = sidebar_cards|merge([{
    'heading': 'Download',
    'body': '<a href="' ~ geo_file.uri.value|file_url ~ '" download>Download GPX</a>',
  }]) %}
{% endif %}

{% set category      = node.schema_category.entity %}
{% set category_key  = category and category.field_key.value ? category.field_key.value : 'default' %}
{% set category_name = category ? category.label : '' %}

{% include '@collections/article/article.twig' with {
  'header': {
    'title':        node.label,
    'date':         node.schema_date_published.value ? node.schema_date_published.value|date('F j, Y') : '',
    'category':     category_name,
    'category_key': category_key,
    'difficulty':   node.schema_difficulty.value,
    'stats':        stats,
    'map_id':       map_id,
  },
  'map_id':              map_id,
  'map_center':          map_center,
  'map_zoom':            13,
  'map_markers':         map_markers,
  'tiles':               tiles,
  'drupal_geo_rendered': null,
  'geojson_url':         geojson_url,
  'elev_gain':           has_stats ? node.schema_elev_gain.value,
  'elev_loss':           has_stats ? node.schema_elev_loss.value,
  'elev_min':            has_stats ? node.schema_elev_min.value,
  'elev_max':            has_stats ? node.schema_elev_max.value,
  'body':                content.body|field_value|render,
  'sidebar_cards':       sidebar_cards,
} only %}

