{#
/**
 * @file
 * Homepage writing grid — renders each article row into card.twig.
 *
 * Template suggestion: views-view-fields--homepage-writing.html.twig
 * Matches View ID: homepage_writing, all displays.
 *
 * With style: default + row: fields, individual field output is available
 * via the fields variable keyed by field ID.
 *
 * Fields available from homepage_writing view:
 *   fields.title.content          — article title (plain text, no link)
 *   fields.path.content           — node URL alias (excluded from display)
 *   fields.schema_date_published.content — formatted date
 *   fields.body.content           — body summary trimmed to 200 chars
 *   fields.schema_category.content — category term label
 *
 * @see @components/card/card.twig
 * @see views-view-fields.html.twig
 */
#}
{% set category = fields.schema_category.content|render|striptags|trim %}

{% include '@components/card/card.twig' with {
  'url':          fields.view_node.content|render|striptags|trim,
  'title':        fields.title.content|render|striptags|trim,
  'excerpt':      fields.body.content|render|striptags|trim,
  'date':         fields.schema_date_published.content|render|striptags|trim,
  'category':     category,
  'category_key': category|lower|replace({' ': '-', '/': '-', '+': '', '&': ''})|trim('-'),
} only %}
