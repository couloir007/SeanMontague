{#
/**
 * @file
 * Homepage places grid — renders each tourist destination row into
 * places-card.twig.
 *
 * Template suggestion: views-view-fields--homepage-places.html.twig
 * Matches View ID: homepage_places, all displays.
 *
 * Fields available from homepage_places view:
 *   fields.title.content           — destination name
 *   fields.path.content            — node URL alias (excluded from display)
 *   fields.field_subtitle.content  — short geographic descriptor
 *   fields.body.content            — body summary trimmed to 200 chars
 *   fields.schema_tourist_type.content — tourist type tags (comma separated)
 *   fields.schema_geo.content      — geofield rendered output
 *
 * @see @components/places-card/places-card.twig
 * @see views-view-fields.html.twig
 */
#}
{# Split comma-separated tourist types into a tags array. #}
{% set types_raw = fields.schema_tourist_type.content|render|striptags|trim %}
{% set tags = types_raw ? types_raw|split(', ')|map(t => t|trim)|filter(t => t) : [] %}

{# Derive display coords from schema_geo rendered output. #}
{% set coords_raw = fields.schema_geo.content|render|striptags|trim %}

{% set coords_parts = coords_raw|split(',') %}

{% if coords_parts|length >= 2 %}
  {% set lat = coords_parts[0]|trim + 0 %}
  {% set lng = coords_parts[1]|trim + 0 %}

  {% set coords = '%0.4f %s, %0.4f %s'|format(
    lat < 0 ? lat * -1 : lat,
    lat < 0 ? 'S' : 'N',
    lng < 0 ? lng * -1 : lng,
    lng < 0 ? 'W' : 'E'
  ) %}
{% else %}
  {% set coords = coords_raw %}
{% endif %}

{% include '@components/places-card/places-card.twig' with {
  'name':     fields.title.content|render|striptags|trim,
  'url':      fields.view_node.content|render|striptags|trim,
  'subtitle': fields.field_subtitle.content|render|striptags|trim,
  'desc':     fields.body.content|render|striptags|trim,
  'coords':   coords,
  'tags':     tags,
} only %}
