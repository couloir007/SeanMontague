{#
/**
 * @file
 * Surface override for facet blocks — direct render, no pattern dependency.
 * When facets are implemented, replace with a proper @components/facet include.
 */
#}

{% if content %}
  <div{{ attributes.addClass('block', 'block-facet') }}>
    {{ title_prefix }}
    {% if label %}
      <h2{{ title_attributes.addClass('block__title') }}>{{ label }}</h2>
    {% endif %}
    {{ title_suffix }}
    <div class="block__content">
      {{ content }}
    </div>
  </div>
{% endif %}
