{# Blog post — writing content type #}
{{ attach_library('surface/article') }}
{{ attach_library('surface/article-header') }}

{% include '@collections/article-header/article-header.twig' with {
  'attributes':    attributes.addClass('paragraph', 'paragraph--type--blog-posting'),
  'title':         label,
  'category':      content.field_category|field_value,
  'category_key':  content.field_category.0['#plain_text']|lower|replace({' ': '-'}),
  'date':          content.field_date_published|field_value,
  'subtitle':      content.field_subtitle|field_value is not empty ? content.field_subtitle|field_value,
} only %}

<div{{ attributes.addClass('paragraph', 'paragraph--type--blog-posting') }}>
  {{ content.field_body|field_value }}
</div>
