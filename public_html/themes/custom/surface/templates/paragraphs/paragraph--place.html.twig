{#
/**
 * @file
 * Place paragraph — renders as a places-card.
 * {{ attributes }} required for Layout Paragraphs edit controls.
 */
#}
{{ attach_library('surface/places-card') }}

{% set lat = paragraph.schema_latitude.value %}
{% set lon = paragraph.schema_longitude.value %}
{% set has_geo = lat is not empty %}

<div{{ attributes.addClass('paragraph', 'paragraph--type--place') }}>
  {% include '@components/places-card/places-card.twig' with {
    'name':     paragraph.label,
    'subtitle': content.schema_address|field_value,
    'coords':   has_geo ? lat|round(4) ~ '° N, ' ~ lon|abs|round(4) ~ '° W',
    'desc':     content.body|field_value,
    'tags':     content.schema_tags|field_value,
  } only %}
</div>
