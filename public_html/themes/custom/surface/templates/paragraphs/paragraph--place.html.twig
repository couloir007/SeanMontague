{# Place — rendered as a places-card #}
{{ attach_library('surface/places-card') }}

{% set geo = paragraph.field_geo is defined and paragraph.field_geo.lat is not empty %}

{% include '@components/places-card/places-card.twig' with {
  'attributes': attributes.addClass('paragraph', 'paragraph--type--place'),
  'name':       label,
  'subtitle':   content.field_address|field_value,
  'coords':     geo ? paragraph.field_geo.lat|round(4) ~ '° N, ' ~ paragraph.field_geo.lon|abs|round(4) ~ '° W',
  'desc':       content.field_body|field_value,
  'tags':       content.field_tags|field_value,
} only %}
