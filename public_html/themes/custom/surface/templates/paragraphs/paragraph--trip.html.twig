{# Trip — travel post with multi-destination map #}
{{ attach_library('surface/surface-article') }}
{{ attach_library('surface/surface-article-header') }}
{{ attach_library('surface/surface-map') }}

{% include '@collections/article-header/surface-article-header.twig' with {
  'attributes': attributes.addClass('paragraph', 'paragraph--type--trip'),
  'title':      label,
  'date':       content.field_date_published|field_value,
  'subtitle':   content.field_subtitle|field_value is not empty ? content.field_subtitle|field_value,
} only %}

{# Build markers array from all referenced destination Place nodes #}
{% set markers = [] %}
{% for item in content.field_destination['#items'] %}
  {% set place = item.entity %}
  {% if place and place.field_geo is defined %}
    {% set markers = markers|merge([{
      'lat':   place.field_geo.lat,
      'lon':   place.field_geo.lon,
      'color': '#3a5a40',
      'label': '<strong>' ~ place.label ~ '</strong>',
    }]) %}
  {% endif %}
{% endfor %}

{% include '@components/map/surface-map.twig' with {
  'map_id':      'trip-map-' ~ paragraph.id(),
  'zoom':        8,
  'interactive': 'true',
  'markers':     markers,
  'modifier':    'surface-map--standalone',
} only %}

<div{{ attributes.addClass('paragraph', 'paragraph--type--trip') }}>
  {{ content.field_body|field_value }}
</div>
