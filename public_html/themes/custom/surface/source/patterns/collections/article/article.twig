{{ attach_library('surface/article') }}
{{ attach_library('surface/article-header') }}
{% block header %}
  {% include "@components/nav/nav.twig" with header %}
{% endblock %}

{% include '@elements/reading-progress/reading-progress.twig' %}

{% if header %}
  {% include '@collections/article-header/article-header.twig' with header only %}
{% endif %}

{# Article-level map + elevation section — full width #}
{% include '@collections/article-map-section/article-map-section.twig' with {
  'label':       map_label,
  'title':       map_title,
  'text':        map_text,
  'map_id':      map_id,
  'map_center':  map_center,
  'map_zoom':    map_zoom,
  'map_markers': map_markers,
  'map_lines':   map_lines,
  'elev_gain':   elev_gain,
  'elev_loss':   elev_loss,
  'elev_min':    elev_min,
  'elev_max':    elev_max,
  'elev_data':          elev_data,
  'geojson_url':        geojson_url,
  'drupal_geo_rendered': drupal_geo_rendered,
  'tiles':              tiles,
} only %}

{# Body + sidebar #}
<div class="article-wrap">
  <article class="article__body">
    {# Drop cap is opt-in: add class="drop-cap" to the first <p> in the body HTML. #}
    {{ body|raw }}
  </article>
  <aside class="article__sidebar">
    {% for card in sidebar_cards %}
      <div class="sidebar-card">
        <div class="sidebar-card__header">{{ card.heading }}</div>
        <div class="sidebar-card__body">{{ card.body|raw }}</div>
      </div>
    {% endfor %}
  </aside>
</div>
