{{ attach_library('surface/trip') }}

{# ── Hero image ── #}
{% if image_url %}
  <div class="trip__hero-image">
    <img src="{{ image_url }}" alt="{{ title|striptags }}" loading="lazy">
  </div>
{% endif %}

{# ── Title block ── #}
<div class="trip__header">
  {% if label %}
    <span class="trip__label">{{ label }}</span>
  {% endif %}
  {% if title %}
    <h1 class="trip__title">{{ title|raw }}</h1>
  {% endif %}
  {% if dates %}
    <div class="trip__dates">{{ dates }}</div>
  {% endif %}
</div>

{# ── Destination strip ── #}
{% if destinations %}
  <div class="trip__strip">
    <div class="trip__strip-inner">
      {% for dest in destinations %}
        <a href="#dest-{{ dest.name|lower|replace({' ': '-', 'é': 'e', 'è': 'e', 'ê': 'e'}) }}" class="trip__strip-name">
          {{- dest.name -}}
        </a>
        {% if not loop.last %}
          <span class="trip__strip-sep" aria-hidden="true">·</span>
        {% endif %}
      {% endfor %}
    </div>
  </div>
{% endif %}

{# ── Stats bar ── #}
{% if stats %}
  {% include '@components/stats-bar/stats-bar.twig' with {
    'stats': stats,
  } only %}
{% endif %}

{# ── Route map ── #}
{% if map_id %}
  <div class="trip__map-wrap">
    <div class="trip__map-header">
      <span class="trip__map-label">{{ map_label|default('Route Map') }}</span>
      <span class="trip__map-note">{{ map_note|default('Scroll to zoom · Click markers for details') }}</span>
    </div>
    {% include '@components/map/map.twig' with {
      'map_id':        map_id,
      'center':        map_center|default('53.0,-8.2'),
      'zoom':          map_zoom|default(7),
      'interactive':   'true',
      'markers':       map_markers|default([]),
      'lines':         map_lines|default([]),
      'tiles':         tiles|default('usgs-topo'),
      'geojson_urls':  geojson_urls|default([]),
    } only %}
  </div>
{% endif %}

{# ── Narrative + sidebar itinerary ── #}
<div class="trip__body-wrap">

  <div class="trip__narrative">
    {% if narrative_kicker %}
      <div class="trip__narrative-kicker">{{ narrative_kicker }}</div>
    {% endif %}
    {% if narrative_heading %}
      <h2 class="trip__narrative-heading">{{ narrative_heading|raw }}</h2>
    {% endif %}
    {% if body %}
      <div class="trip__prose">{{ body|raw }}</div>
    {% endif %}
  </div>

  {% if destinations %}
    <aside class="trip__sidebar">
      <div class="trip__sidebar-header">Itinerary</div>
      <ul class="trip__itinerary">
        {% for dest in destinations %}
          <li>
            <a href="#dest-{{ dest.name|lower|replace({' ': '-', 'é': 'e', 'è': 'e', 'ê': 'e'}) }}"
               class="trip__itinerary-item">
              <span class="trip__itinerary-num">{{ '%02d'|format(loop.index) }}</span>
              <span class="trip__itinerary-body">
                <span class="trip__itinerary-place">{{ dest.name }}</span>
                {% if dest.dates or dest.region %}
                  <span class="trip__itinerary-meta">
                    {{- dest.dates ? dest.dates : '' -}}
                    {{- dest.dates and dest.region ? ' · ' : '' -}}
                    {{- dest.region ? dest.region : '' -}}
                  </span>
                {% endif %}
              </span>
            </a>
          </li>
        {% endfor %}
      </ul>
    </aside>
  {% endif %}

</div>

{# ── Destination cards ── #}
{% if destinations %}
  <div class="trip__cards-section">
    <div class="trip__cards-header">
      <div class="trip__cards-title">Destinations</div>
      <div class="trip__cards-count">{{ destinations|length }} places</div>
    </div>
    <div class="trip__cards-grid">
      {% for dest in destinations %}
        {% set dest_slug = dest.name|lower|replace({' ': '-', 'é': 'e', 'è': 'e', 'ê': 'e'}) %}
        <a href="#dest-{{ dest_slug }}" id="dest-{{ dest_slug }}" class="trip__dest-card">
          {% if dest.lat and dest.lon %}
            <div class="trip__card-map"
                 data-lat="{{ dest.lat }}"
                 data-lon="{{ dest.lon }}"
                 data-name="{{ dest.name }}"
                 data-num="{{ loop.index }}">
            </div>
          {% else %}
            <div class="trip__card-map-placeholder"></div>
          {% endif %}
          <div class="trip__card-body">
            <div class="trip__card-num">{{ '%02d'|format(loop.index) }}</div>
            <div class="trip__card-name">{{ dest.name }}</div>
            {% if dest.region or dest.dates %}
              <div class="trip__card-region">
                {{- dest.region ? dest.region : '' -}}
                {{- dest.region and dest.dates ? ' · ' : '' -}}
                {{- dest.dates ? dest.dates : '' -}}
              </div>
            {% endif %}
          </div>
          <span class="trip__card-arrow" aria-hidden="true">→</span>
        </a>
      {% endfor %}
    </div>
  </div>
{% endif %}
