{{ attach_library('surface/article-map-section') }}

<div class="article-map-section">
  <div class="article-map-section__map-container">
    {% if drupal_geo_rendered %}
      {{ drupal_geo_rendered }}
    {% elseif map_id %}
      {# 'lines' is merged in only when truthy — the Drupal article path always
         passes map_lines as null, and passing 'lines': null would override a
         real array. Storybook fixtures pass real arrays, which survive. #}
      {% include '@components/map/map.twig' with {
        'map_id':      map_id,
        'center':      map_center,
        'zoom':        map_zoom|default(13),
        'interactive': 'true',
        'markers':     map_markers,
        'geojson_url':  geojson_url,
        'geojson_urls': geojson_urls,
        'tiles':       tiles|default('usgs-topo'),
      }|merge(map_lines ? { 'lines': map_lines } : {}) only %}
    {% endif %}
  </div>

  {% if elev_gain or geojson_url %}
    <div class="article-map-section__elevation-container">
      {% include '@components/elevation-profile/elevation-profile.twig' with {
        'gain':        elev_gain,
        'loss':        elev_loss,
        'min_elev':    elev_min,
        'max_elev':    elev_max,
        'elev_data':   elev_data,
        'geojson_url': geojson_url,
        'canvas_id':   (map_id|default('article-map')) ~ '-elevation',
        'map_id':      map_id|default('article-map'),
      } only %}
    </div>
  {% endif %}
</div>
