{{ attach_library('surface/surface-article-map-section') }}

<div class="surface-article-map-section">
  <div class="surface-article-map-section__map-container">
    {% include '@components/map/surface-map.twig' with {
      'map_id':      map_id|default('article-map'),
      'center':      map_center,
      'zoom':        map_zoom|default(13),
      'interactive': 'true',
      'markers':     map_markers,
      'lines':       map_lines,
    } only %}
  </div>

  {% if elev_gain or elev_data %}
    <div class="surface-article-map-section__elevation-container">
      {% include '@components/elevation-profile/surface-elevation-profile.twig' with {
        'gain':      elev_gain,
        'loss':      elev_loss,
        'min_elev':  elev_min,
        'max_elev':  elev_max,
        'elev_data': elev_data,
        'canvas_id': (map_id|default('article-map')) ~ '-elevation',
        'map_id':    map_id|default('article-map'),
      } only %}
    </div>
  {% endif %}
</div>
