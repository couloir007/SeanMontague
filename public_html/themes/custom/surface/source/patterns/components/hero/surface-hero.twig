{{ attach_library('surface/surface-hero') }}

<header class="surface-hero{{ modifier ? ' ' ~ modifier }}" id="home">

  <div class="surface-hero__map-bg">
    {% include '@components/map/surface-map.twig' with {
      'map_id':      map_id|default('hero-map'),
      'center':      map_center|default('44.593,-71.918'),
      'zoom':        map_zoom|default(11),
      'interactive': 'false',
      'markers':     map_markers|default([]),
      'lines':       map_lines|default([]),
    } only %}
  </div>

  <div class="surface-hero__overlay"></div>

  <div class="surface-hero__content">
    {% if eyebrow %}
      <p class="surface-hero__eyebrow">{{ eyebrow }}</p>
    {% endif %}
    {% if name %}
      <h1 class="surface-hero__name">{{ name|raw }}</h1>
    {% endif %}
    {% if tagline %}
      <p class="surface-hero__tagline">{{ tagline }}</p>
    {% endif %}
    {% if cta_primary or cta_ghost %}
      <div class="surface-hero__cta-row">
        {% if cta_primary %}
          <a href="{{ cta_primary.url|default('#') }}" class="surface-hero__btn-primary">{{ cta_primary.text }}</a>
        {% endif %}
        {% if cta_ghost %}
          <a href="{{ cta_ghost.url|default('#') }}" class="surface-hero__btn-ghost">{{ cta_ghost.text }}</a>
        {% endif %}
      </div>
    {% endif %}
  </div>

  {% if categories %}
    <div class="surface-hero__categories">
      {% for cat in categories %}
        <a href="{{ cat.url|default('#') }}" class="surface-hero__cat">
          {{ cat.icon ? cat.icon ~ ' ' }}{{ cat.text }}
        </a>
      {% endfor %}
    </div>
  {% endif %}

</header>
