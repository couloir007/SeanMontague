{{ attach_library('surface/marquee') }}
<div class="marquee{{ modifier ? ' ' ~ modifier }}">
  <div class="marquee__track">
    {% for i in 1..2 %}
      {% for item in items %}
        <span class="marquee__item">{{ item }} <span class="marquee__dot">◆</span></span>
      {% endfor %}
    {% endfor %}
  </div>
</div>
