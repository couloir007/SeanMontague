{{ attach_library('surface/about') }}

{#
  About — editorial two-column section.
  Wears the shared .section frame (padding, border, --alt tint, eyebrow
  spacing + responsive padding all come from section.css). About owns ONLY
  its inner grid (.about__grid is 1fr 1.5fr, not a card grid — that is why it
  does not route through the section.twig embed slot).

  Depends on surface/section for the frame classes — see surface.libraries.yml.
#}

<section class="about section{{ modifier ? ' ' ~ modifier }}" id="about">
  {% if label %}
    <div class="section__eyebrow">
      {% include '@elements/eyebrow/eyebrow.twig' with {
        eyebrow: { text: label, modifier: label_modifier|default('') }
      } only %}
    </div>
  {% endif %}

  <div class="about__grid">
    <div>
      {% if title %}
        <h2 class="about__aside-title">{{ title|raw }}</h2>
      {% endif %}
      {% if skills %}
        <ul class="about__skills">
          {% for skill in skills %}
            <li>{{ skill }}</li>
          {% endfor %}
        </ul>
      {% endif %}
    </div>
    <div class="about__body">
      {% if paragraphs %}
        {% for p in paragraphs %}
          <p>{{ p }}</p>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>
