{{ attach_library('surface/footer') }}

<footer class="footer{{ modifier ? ' ' ~ modifier }}">
  <div class="footer__brand">{{ brand_text|default('Sean Montague · Burke, VT') }}</div>
  <p class="footer__copy">{{ copyright_text|default('© 2025 Sean Montague') }}</p>
  <ul class="footer__links">
    {% for item in links %}
      <li><a href="{{ item.url }}">{{ item.text }}</a></li>
    {% endfor %}
  </ul>
</footer>
