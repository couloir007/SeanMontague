{{ attach_library('surface/map') }}

<div
  id="{{ map_id|default('map') }}"
  class="map{{ modifier ? ' ' ~ modifier }}"
  data-map-center="{{ center|default('44.593,-71.918') }}"
  data-map-zoom="{{ zoom|default(12) }}"
  data-map-interactive="{{ interactive|default('true') }}"
  {% if markers %}data-map-markers="{{ markers|json_encode|e('html_attr') }}"{% endif %}
  {% if lines %}data-map-lines="{{ lines|json_encode|e('html_attr') }}"{% endif %}
></div>
