{{ attach_library('surface/surface-contact') }}

<section class="surface-contact{{ modifier ? ' ' ~ modifier }}" id="contact">
  {% if label %}
    <span class="surface-contact__label">{{ label }}</span>
  {% endif %}
  {% if headline %}
    <h2 class="surface-contact__headline">{{ headline }}</h2>
  {% endif %}
  {% if sub %}
    <p class="surface-contact__sub">{{ sub }}</p>
  {% endif %}
  {% if email %}
    <a href="mailto:{{ email }}" class="surface-contact__email">{{ email }}</a>
  {% endif %}
</section>
