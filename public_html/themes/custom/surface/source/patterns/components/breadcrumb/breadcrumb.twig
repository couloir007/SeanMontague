{{ attach_library('surface/breadcrumb') }}

<nav class="breadcrumb{{ modifier ? ' ' ~ modifier }}" aria-label="{{ 'Breadcrumb'|t }}">
  <ol class="breadcrumb__list">
    {% for item in breadcrumb %}
      <li class="breadcrumb__item{{ loop.last ? ' breadcrumb__item--active' }}">
        {% if item.url and not loop.last %}
          <a href="{{ item.url }}" class="breadcrumb__link">{{ item.text }}</a>
        {% else %}
          <span class="breadcrumb__current" aria-current="page">{{ item.text }}</span>
        {% endif %}
      </li>
    {% endfor %}
  </ol>
</nav>
