{{ attach_library('surface/surface-card') }}

<a href="{{ url|default('#') }}" class="surface-card{{ modifier ? ' ' ~ modifier }}">
  {% if category %}
    <span class="surface-card__category surface-card__category--{{ category_key|default('default') }}">{{ category }}</span>
  {% endif %}
  {% if title %}
    <h3 class="surface-card__title">{{ title }}</h3>
  {% endif %}
  {% if excerpt %}
    <p class="surface-card__excerpt">{{ excerpt }}</p>
  {% endif %}
  {% if date or readtime %}
    <span class="surface-card__meta">{{ date }}{% if date and readtime %} · {% endif %}{{ readtime }}</span>
  {% endif %}
</a>
