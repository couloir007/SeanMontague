{{ attach_library('surface/card') }}

<a href="{{ url|default('#') }}" class="card{{ modifier ? ' ' ~ modifier }}">
  {% if category %}
    <span class="card__category card__category--{{ category_key|default('default') }}">{{ category }}</span>
  {% endif %}
  {% if title %}
    <h3 class="card__title">{{ title }}</h3>
  {% endif %}
  {% if excerpt %}
    <p class="card__excerpt">{{ excerpt }}</p>
  {% endif %}
  {% if date or readtime %}
    <span class="card__meta">{{ date }}{% if date and readtime %} · {% endif %}{{ readtime }}</span>
  {% endif %}
</a>
