{{ attach_library('surface/surface-places-card') }}

<div class="surface-places-card{{ modifier ? ' ' ~ modifier }}">
  <div class="surface-places-card__meta">
    {% if subtitle %}
      <span class="surface-places-card__subtitle">{{ subtitle }}</span>
    {% endif %}
    {% if coords %}
      <span class="surface-places-card__coords">{{ coords }}</span>
    {% endif %}
  </div>
  {% if name %}
    <h3 class="surface-places-card__name">{{ name }}</h3>
  {% endif %}
  {% if desc %}
    <p class="surface-places-card__desc">{{ desc }}</p>
  {% endif %}
  {% if tags %}
    <div class="surface-places-card__tags">
      {% for tag in tags %}
        <span class="surface-places-card__tag">{{ tag }}</span>
      {% endfor %}
    </div>
  {% endif %}
</div>
