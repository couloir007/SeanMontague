{% extends "@layouts/site-container/site-container.twig" %}

{% block header %}
  {% include "@components/nav/nav.twig" with header %}
{% endblock %}

{% block main %}
{#  {{ attach_library('surface/site-homepage') }}#}
  {% include '@components/hero/hero.twig' with {
    'map_id':      hero.map_id,
    'map_center':  hero.map_center,
    'map_zoom':    hero.map_zoom,
    'map_markers': hero.map_markers,
    'eyebrow':     hero.eyebrow,
    'name':        hero.name,
    'tagline':     hero.tagline,
    'cta_primary': hero.cta_primary,
    'cta_ghost':   hero.cta_ghost,
    'categories':  hero.categories
  } only %}

  {% include '@collections/map-section/map-section.twig' with {
    'label':      maps.label,
    'title':      maps.title,
    'text':       maps.text,
    'map_id':     maps.map_id,
    'map_center': maps.map_center,
    'map_zoom':   maps.map_zoom,
    'links':      maps.links
  } only %}

  {% embed '@components/section/section.twig' with {
    id: 'writing',
    eyebrow: 'Writing',
    grid_modifier: 'section__grid--cards',
  } %}
    {% block content %}
      {% for card_item in writing.cards %}
        {% include '@components/card/card.twig' with {
          card_items:
          category: card_item.category,
          modifier: card_item.modifier,
          title:    card_item.title,
          excerpt:  card_item.excerpt,
          meta:     card_item.meta,
        } only %}
      {% endfor %}
    {% endblock %}
  {% endembed %}

  {% embed '@components/section/section.twig' with {
    id: 'places',
    eyebrow: 'Places & Projects',
    modifier: 'section--alt',
    grid_modifier: 'section__grid--places',
  } %}
    {% block content %}
      {% for place in places.items %}
        {% include '@components/places-card/places-card.twig' with {
          label:    place.label,
          coords:   place.coords,
          subtitle: place.subtitle,
          name:     place.name,
          desc:     place.desc,
          tags:     place.tags,
        } only %}
      {% endfor %}
    {% endblock %}
  {% endembed %}

  {% embed '@components/section/section.twig' with {
    id: 'places',
    eyebrow: 'Places & Projects',
    modifier: 'section--alt',
    grid_modifier: 'section__grid--places',
  } %}
    {% block content %}
      {% for place in places.items %}
        {% include '@components/places-card/places-card.twig' with {
          label:    place.label,
          coords:   place.coords,
          subtitle: place.subtitle,
          name:     place.name,
          desc:     place.desc,
          tags:     place.tags,
        } only %}
      {% endfor %}
    {% endblock %}
  {% endembed %}

  {% include '@components/about/about.twig' with {
    label:      about.label,
    title:      about.title,
    skills:     about.skills,
    paragraphs: about.paragraphs
  } only %}

  {% include '@components/contact/contact.twig' with {
    label:      contact.label,
    headline:   contact.headline,
    sub:        contact.sub,
    email:      contact.email
  } only %}
{% endblock %}

{% block footer %}
  {% include "@components/footer/footer.twig" with footer %}
{% endblock %}
