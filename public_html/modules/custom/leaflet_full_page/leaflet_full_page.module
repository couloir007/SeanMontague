/**
 * Implements hook_theme_suggestions_HOOK_alter().
 */
function leaflet_full_page_theme_suggestions_views_view_alter(array &$suggestions, array $variables) {
  $view = $variables['view'];
  $suggestions[] = 'views_view__leaflet_full_page__' . $view->id();
  $suggestions[] = 'views_view__leaflet_full_page__' . $view->current_display;
  $suggestions[] = 'views_view__leaflet_full_page__' . $view->id() . '__' . $view->current_display;
}

/**
 * Implements hook_theme_suggestions_HOOK_alter().
 */
function leaflet_full_page_theme_suggestions_views_view_unformatted_alter(array &$suggestions, array $variables) {
  $view = $variables['view'];
  $suggestions[] = 'views_view_unformatted__leaflet_full_page__' . $view->id();
  $suggestions[] = 'views_view_unformatted__leaflet_full_page__' . $view->current_display;
  $suggestions[] = 'views_view_unformatted__leaflet_full_page__' . $view->id() . '__' . $view->current_display;
}
