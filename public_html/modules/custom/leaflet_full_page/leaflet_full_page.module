<?php

use Drupal\views\ViewExecutable;

/**
 * Implements hook_theme().
 */
function leaflet_full_page_theme($existing, $type, $theme, $path) {
  $module_path = \Drupal::service('extension.list.module')->getPath('leaflet_full_page');
  return [
    'views_view__leaflet_full_page__legend' => [
      'template' => 'views-view--leaflet-full-page--legend', // Filename without .html.twig
      'path' => $module_path . '/templates',
    ],
    'views_view__leaflet_full_page__no_legend' => [
      'template' => 'views-view--leaflet-full-page--no-legend', // Filename without .html.twig
      'path' => $module_path . '/templates',
    ],
  ];
}

