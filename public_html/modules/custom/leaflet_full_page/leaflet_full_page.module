<?php

use Drupal\views\ViewExecutable;
use Drupal\Core\Form\FormStateInterface;

/**
 * Implements hook_theme().
 */
function leaflet_full_page_theme($existing, $type, $theme, $path) {
    $module_path = \Drupal::service('extension.list.module')
        ->getPath('leaflet_full_page');
    return [
        'views_view__leaflet_full_page__legend' => [
            'template' => 'views-view--leaflet-full-page--legend',
            'path' => $module_path . '/templates',
        ],
        'views_view__leaflet_full_page__no_legend' => [
            'template' => 'views-view--leaflet-full-page--no_legend',
            'path' => $module_path . '/templates',
        ],
    ];
}

/**
 * Implements hook_preprocess_html().
 */
function leaflet_full_page_preprocess_html(&$variables) {
    $request = \Drupal::request();
    if ($request->attributes->has('view_id')) {
        $view_id = $request->attributes->get('view_id');
        if (strpos($view_id, 'leaflet_full_page') !== FALSE) {
            $variables['attributes']['class'][] = 'leaflet-full-page';
        }
    }
}

/**
 * Implements hook_theme_suggestions_views_view_alter().
 */
function leaflet_full_page_theme_suggestions_views_view_alter(array &$suggestions, array $variables) {
    $view = $variables['view'];
    $leaflet_full_page_extenders = $view->display_handler->getOption('display_extenders')['leaflet_full_page_display_extender'] ?? [];

    if (isset($leaflet_full_page_extenders['template'])) {
        $suggestions[] = 'views_view__leaflet_full_page__' . $leaflet_full_page_extenders['template'];
    }
}

/**
 * Checks if the provided view is a "leaflet full page" mapping view.
 */
function _leaflet_full_page_is_si_mapping_view($view, &$options = []): bool {
    if (
        !!($extenders = $view->getDisplay()->getExtenders())
        && (array_key_exists('leaflet_full_page_view', $extenders))
        && !empty($extenders['leaflet_full_page_view']->options['template'])
    ) {
        $options = $extenders['leaflet_full_page_view']->options;
        return TRUE;
    }

    return FALSE;
}

/**
 * Implements hook_form_alter().
 */
function leaflet_full_page_form_alter(&$form, FormStateInterface $form_state, $form_id) {
    if (strpos($form_id, 'views_exposed_form') !== FALSE) {
        $view = $form_state->get('view');

        if (isset($view->filter['bundle'])) {
            $table = $view->filter['bundle']->table;
            if (strpos($table, 'leaflet_full_page') !== FALSE) {
                if (_leaflet_full_page_is_si_mapping_view($view, $options)
                    && !empty($options['template'])) {
                    $form['leaflet_full_page'] = [
                        'template' => $options['template'],
                    ];
                }
            }
        }
    }
}

/**
 * Implements hook_views_pre_render().
 */
function leaflet_full_page_views_pre_render(ViewExecutable $view): void {
    if (strpos($view->id(), 'leaflet_full_page') !== FALSE) {
        if (strpos($view->current_display, 'items') === FALSE) {
            $existing_settings = $view->element['#attached']['drupalSettings']['leaflet_full_page'] ?? [];

            $display = $view->display_handler;
            $path = $display->getOption('path');
            $view->element['#attached']['drupalSettings']['leaflet_full_page']['currentPath'] = $path;

            if (empty($existing_settings['currentDisplay'])) {
                $view->element['#attached']['drupalSettings']['leaflet_full_page']['currentDisplay'] = $view->current_display;
            }

            $config = \Drupal::config('leaflet_full_page.settings');
            $endpoint = $config->get('endpoint_path') ?: '/leaflet-full-page/map-items';
            $view->element['#attached']['drupalSettings']['leaflet_full_page']['itemsEndpoint'] = $endpoint;
        }
    }
}

/**
 * Helper function to render a field.
 */
function _leaflet_full_page_render_field($entity, $field_name, $view_mode = 'default') {
    if (!$entity->hasField($field_name) || $entity->get($field_name)->isEmpty()) {
        return '';
    }

    $field = $entity->get($field_name);
    $build = $field->view($view_mode);
    return \Drupal::service('renderer')->render($build);
}
