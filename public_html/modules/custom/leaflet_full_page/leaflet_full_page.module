/**
 * Implements hook_theme_suggestions_HOOK_alter().
 */
function leaflet_full_page_theme_suggestions_views_view_alter(array &$suggestions, array $variables) {
  $view = $variables['view'];
  $si_mapping_extenders = $view->display_handler->getOption('display_extenders')['si_mapping_display_extender'] ?? [];

  if (isset($si_mapping_extenders['template'])) {
    $suggestions[] = 'views_view__leaflet_full_page__' . $si_mapping_extenders['template'];
  } else {

  }
}

