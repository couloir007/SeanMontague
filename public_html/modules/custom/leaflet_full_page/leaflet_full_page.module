<?php

use Drupal\views\ViewExecutable;

/**
 * Implements hook_theme().
 */
function leaflet_full_page_theme($existing, $type, $theme, $path) {
  $module_path = \Drupal::service('extension.list.module')->getPath('leaflet_full_page');
  return [
    'views_view__leaflet_full_page__leaflet_full_page' => [
      'template' => 'views-view--leaflet-full-page--leaflet-full-page', // Filename without .html.twig
      'path' => $module_path . '/templates',
    ],
    'views_view_unformatted__leaflet_full_page__leaflet_full_page' => [
      'template' => 'views-view-unformatted--leaflet-full-page--leaflet-full-page', // Filename without .html.twig
      'path' => $module_path . '/templates',
    ],
  ];
}

