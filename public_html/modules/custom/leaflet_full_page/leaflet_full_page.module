function _leaflet_full_page_is_si_mapping_view($view, &$options = []): bool {
  if(
    !!($extenders = $view->getDisplay()->getExtenders())
    && (array_key_exists('leaflet_full_page_view', $extenders))
    && !empty($extenders['leaflet_full_page_view']->options['template'])
  ) {
    $options = $extenders['leaflet_full_page_view']->options;
    return TRUE;
  }

  return False;
}

/**
 * Implements hook_form_alter().
 *
 * This catches all forms; then we check for the Views display edit form.
 */
function leaflet_full_page_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  if (strpos($form_id, 'views_exposed_form') !== FALSE) {
    $view = $form_state->get('view');

    if (isset($view->filter['bundle'])) {
      $table = $view->filter['bundle']->table;
      if (strpos($table, 'leaflet_full_page') !== FALSE) {
        if(_leaflet_full_page_is_si_mapping_view($view, $options)
          && !empty($options['template'])) {
          $form['leaflet_full_page'] = [
            'template' => $options['template'],
          ];
        }
      }
    }
  }
}
