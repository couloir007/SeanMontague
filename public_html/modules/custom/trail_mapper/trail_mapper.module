<?php

/**
 * @file
 * GeoShape conversion hook for trail_mapper module.
 *
 * Add to: public_html/modules/custom/trail_mapper/trail_mapper.module
 *
 * On node presave, reads schema_geoshape (GPX or GeoJSON), converts to
 * normalized GeoJSON with Z values in feet, and overwrites schema_geoshape
 * with the result. After save, schema_geoshape always contains a .geojson
 * file regardless of what was uploaded.
 *
 * Author workflow:
 *   1. Author uploads .gpx or .geojson to schema_geoshape
 *   2. This hook fires on save
 *   3. schema_geoshape is overwritten with normalized .geojson
 *   4. Drupal Leaflet and elevation-profile.js both read schema_geoshape
 *
 * Elevation unit assumption: all uploaded files store elevation in meters.
 * Strava, Garmin, Gaia GPS, and Komoot all export in meters. Hand-crafted
 * GeoJSON on this site also uses meters by convention.
 * If a file uses feet, pre-convert before uploading.
 */
use Drupal\Core\Entity\EntityInterface;
use Drupal\media\MediaInterface;
use Drupal\trail_mapper\Form\TrailMapperSettingsForm;

/**
 * Implements hook_entity_presave().
 *
 * Node-coupled geoshape work only — waypoint→POI extraction and the
 * multi-value schema_geoshape re-set. Per-media file conversion lives on the
 * media presave hook (trail_mapper_media_presave). processEntity() ignores
 * non-node entities, so this is a no-op for the media saved above.
 *
 * Uses presave so any node-side change is part of the same save — no second
 * save, no recursion.
 */
function trail_mapper_entity_presave(EntityInterface $entity): void {
  \Drupal::service('trail_mapper.geo_shape_converter')->processEntity($entity);
}

/**
 * Implements hook_ENTITY_TYPE_presave() for media.
 *
 * Converts a data_download geoshape file in place whenever the file is new or
 * replaced, and re-bakes route_type when only the field_route_type tag changes.
 * Running on the media's own presave means the same conversion happens however
 * the media is created: trip_import, standalone upload, or file replacement.
 *
 * No recursion: GeoShapeConverter::overwriteGeoshape() saves only the file
 * entity, never the media — Drupal persists the media after this hook returns.
 */
function trail_mapper_media_presave(MediaInterface $media): void {
  if ($media->bundle() !== 'data_download' || !$media->hasField('field_media_file')) {
    return;
  }

  /** @var \Drupal\trail_mapper\Service\GeoShapeConverter $converter */
  $converter = \Drupal::service('trail_mapper.geo_shape_converter');

  $original = $media->original ?? NULL;
  $oldFid = $original ? ($original->get('field_media_file')->target_id ?? NULL) : NULL;
  $newFid = $media->get('field_media_file')->target_id ?? NULL;
  $isNew = !$original;
  $fileChanged = $isNew || ($oldFid !== $newFid);

  if ($fileChanged) {
    // New media or replaced file — full conversion + route_type bake.
    // (Per-feature stats are added in a later step.)
    $converter->processMedia($media);
    return;
  }

  // File unchanged. If only the route_type tag changed, re-bake route_type into
  // the existing .geojson: processMedia() detects the current (.geojson) file
  // and runs normalizeGeoJson(), which re-stamps properties.route_type without
  // touching geometry or stats. Skips entirely when the tag is unchanged.
  if ($media->hasField('field_route_type')) {
    $oldRouteTid = $original->get('field_route_type')->target_id ?? NULL;
    $newRouteTid = $media->get('field_route_type')->target_id ?? NULL;
    if ($oldRouteTid !== $newRouteTid) {
      $converter->processMedia($media);
    }
  }
}

/**
 * Implements hook_page_attachments().
 *
 * Passes tile config to map.js via drupalSettings.trailMapper.
 */
function trail_mapper_page_attachments(array &$attachments): void {
  $tile = TrailMapperSettingsForm::resolvedTile();
  $attachments['#attached']['drupalSettings']['trailMapper'] = [
    'tileKey'         => $tile['key'],
    'tileUrl'         => $tile['url'],
    'tileAttribution' => $tile['attribution'],
    'tileMaxZoom'     => $tile['maxZoom'] ?? 16,
    'tileSets'        => TrailMapperSettingsForm::allTileSets(),
    'elevationUnit'   => Drupal::config('trail_mapper.settings')->get('elevation_unit') ?? 'feet',
    'routeStyles'     => _trail_mapper_route_styles(),
  ];
}

/**
 * Builds the route_type term style map for drupalSettings.trailMapper.
 *
 * Loads every term in the route_type vocabulary and keys the map by each
 * term's field_key. Each value carries the styling fields — color
 * (field_color, raw), weight (field_line_weight, raw), and dash, which
 * translates field_dash_pattern's keyword into an SVG dashArray string for
 * Leaflet (solid / unrecognised values omit the key). Any missing field is
 * simply omitted.
 *
 * @return array
 *   Map of route key => { color?, dash?, weight? } where dash is an SVG
 *   dashArray string when present.
 */
function _trail_mapper_route_styles(): array {
  $styles = [];

  try {
    $terms = \Drupal::entityTypeManager()
      ->getStorage('taxonomy_term')
      ->loadByProperties(['vid' => 'route_type']);
  }
  catch (\Exception $e) {
    return $styles;
  }

  foreach ($terms as $term) {
    $key = $term->hasField('field_key') ? $term->get('field_key')->value : NULL;
    if (!$key) {
      continue;
    }

    $style = [];
    if ($term->hasField('field_color') && !$term->get('field_color')->isEmpty()) {
      $style['color'] = $term->get('field_color')->value;
    }
    if ($term->hasField('field_dash_pattern') && !$term->get('field_dash_pattern')->isEmpty()) {
      // Translate the keyword to an SVG dashArray (what Leaflet's dashArray
      // expects), tuned for the line weights in use. 'solid' and any
      // unrecognised value omit the key entirely → solid line.
      $dash = match ($term->get('field_dash_pattern')->value) {
        'dashed' => '8 6',
        'dotted' => '2 6',
        default  => NULL,
      };
      if ($dash !== NULL) {
        $style['dash'] = $dash;
      }
    }
    if ($term->hasField('field_line_weight') && !$term->get('field_line_weight')->isEmpty()) {
      $style['weight'] = $term->get('field_line_weight')->value;
    }

    $styles[$key] = $style;
  }

  return $styles;
}


