<?php

/**
 * @file
 * Primary module hooks for Map Page module.
 *
 * Provides full-page Leaflet mapping functionality driven by geo_entity
 * bundles. Exposes a GeoJSON endpoint at /map-page/map-items/{bundle} and
 * wires Views display extender template suggestions for map page displays.
 */

use Drupal\views\ViewExecutable;
use Drupal\Core\Form\FormStateInterface;

/**
 * Implements hook_theme().
 *
 * Registers custom Views templates for map page displays. Template selection
 * is driven by the map_page_display_extender 'template' option — either
 * 'legend' (sidebar + map) or 'no_legend' (full-width map).
 */
function map_page_theme($existing, $type, $theme, $path) {
  $module_path = \Drupal::service('extension.list.module')
    ->getPath('map_page');
  return [
    'views_view__map_page__legend' => [
      'template' => 'views-view--map-page--legend',
      'path' => $module_path . '/templates',
    ],
    'views_view__map_page__no_legend' => [
      'template' => 'views-view--map-page--no_legend',
      'path' => $module_path . '/templates',
    ],
  ];
}

/**
 * Implements hook_preprocess_html().
 *
 * Adds a 'map-page' body class when the current page is a map_page view.
 * Used to apply full-height layout CSS without affecting other pages.
 */
function map_page_preprocess_html(&$variables) {
  $request = \Drupal::request();
  if ($request->attributes->has('view_id')) {
    $view_id = $request->attributes->get('view_id');
    if (strpos($view_id, 'map_page') !== FALSE) {
      $variables['attributes']['class'][] = 'map-page';
    }
  }
}

/**
 * Implements hook_theme_suggestions_views_view_alter().
 *
 * Adds a template suggestion based on the map_page_display_extender
 * 'template' option, allowing per-display template overrides without
 * hardcoding view/display IDs in the theme layer.
 */
function map_page_theme_suggestions_views_view_alter(array &$suggestions, array $variables) {
  $view = $variables['view'];
  $map_page_extenders = $view->display_handler->getOption('display_extenders')['map_page_display_extender'] ?? [];

  if (isset($map_page_extenders['template'])) {
    $suggestions[] = 'views_view__map_page__' . $map_page_extenders['template'];
  }
}

/**
 * Checks if the provided view is a map page display.
 *
 * Returns TRUE when the view has an active map_page_view display extender
 * with a 'template' option set. Populates $options by reference with the
 * extender options when found.
 *
 * @param \Drupal\views\ViewExecutable $view
 *   The view to inspect.
 * @param array $options
 *   Populated by reference with display extender options when found.
 *
 * @return bool
 *   TRUE if this is a map page display, FALSE otherwise.
 */
function _map_page_is_mapping_view($view, array &$options = []): bool {
  if (
    !!($extenders = $view->getDisplay()->getExtenders())
    && (array_key_exists('map_page_view', $extenders))
    && !empty($extenders['map_page_view']->options['template'])
  ) {
    $options = $extenders['map_page_view']->options;
    return TRUE;
  }

  return FALSE;
}

/**
 * Implements hook_form_alter().
 *
 * Passes the display extender template option into the exposed filter form
 * as a hidden value so the JS layer can read which map template is active.
 */
function map_page_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  if (strpos($form_id, 'views_exposed_form') !== FALSE) {
    $view = $form_state->get('view');

    if (isset($view->filter['bundle'])) {
      $table = $view->filter['bundle']->table;
      if (strpos($table, 'map_page') !== FALSE) {
        if (_map_page_is_mapping_view($view, $options)
          && !empty($options['template'])) {
          $form['map_page'] = [
            'template' => $options['template'],
          ];
        }
      }
    }
  }
}

/**
 * Implements hook_views_pre_render().
 *
 * Attaches drupalSettings for map page views — current path, display ID,
 * and the GeoJSON items endpoint URL. These are read by map-interaction.js
 * to load map markers after the page renders.
 */
function map_page_views_pre_render(ViewExecutable $view): void {
  if (strpos($view->id(), 'map_page') !== FALSE) {
    if (strpos($view->current_display, 'items') === FALSE) {
      $existing_settings = $view->element['#attached']['drupalSettings']['map_page'] ?? [];

      $display = $view->display_handler;
      $path = $display->getOption('path');
      $view->element['#attached']['drupalSettings']['map_page']['currentPath'] = $path;

      if (empty($existing_settings['currentDisplay'])) {
        $view->element['#attached']['drupalSettings']['map_page']['currentDisplay'] = $view->current_display;
      }

      $config = \Drupal::config('map_page.settings');
      $endpoint = $config->get('endpoint_path') ?: '/map-page/map-items';
      $view->element['#attached']['drupalSettings']['map_page']['itemsEndpoint'] = $endpoint;
    }
  }
}

/**
 * Renders a single field to a string for use in templates or API output.
 *
 * @param \Drupal\Core\Entity\EntityInterface $entity
 *   The entity containing the field.
 * @param string $field_name
 *   The machine name of the field to render.
 * @param string $view_mode
 *   The view mode to use for rendering. Defaults to 'default'.
 *
 * @return string
 *   Rendered field markup, or empty string if field is absent or empty.
 */
function _map_page_render_field($entity, string $field_name, string $view_mode = 'default'): string {
  if (!$entity->hasField($field_name) || $entity->get($field_name)->isEmpty()) {
    return '';
  }

  $field = $entity->get($field_name);
  $build = $field->view($view_mode);
  return \Drupal::service('renderer')->render($build);
}
